<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="LoopMeet.App.Features.Meetups.Views.CreateMeetupPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="CreateMeetupPageRoot"
    Title="Create Meetup">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="12">
            <Label Text="Create Meetup" FontSize="24" FontAttributes="Bold" />

            <Border
                Padding="16"
                Style="{StaticResource BubbleCardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <VerticalStackLayout Spacing="12" IsVisible="{Binding ShowFormFields}">
                        <Label Text="Title" FontAttributes="Bold" FontSize="14" />
                        <Entry Placeholder="What's the meetup about?" Text="{Binding Title}" />

                        <Label Text="Date" FontAttributes="Bold" FontSize="14" />
                        <DatePicker Date="{Binding ScheduledDate}" MinimumDate="{Binding MinimumDate}" />

                        <Label Text="Time" FontAttributes="Bold" FontSize="14" />
                        <TimePicker Time="{Binding ScheduledTime}" />
                    </VerticalStackLayout>

                    <Label Text="Location" FontAttributes="Bold" FontSize="14" />
                    <Label Text="{Binding LocationDisplay}" FontSize="13"
                        TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                    <Entry Placeholder="Search for a location..." Text="{Binding LocationSearchText}" />
                    <VerticalStackLayout
                        BindableLayout.ItemsSource="{Binding Predictions}"
                        Spacing="4">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Margin="0,2"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray600}}">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding BindingContext.SelectPredictionCommand, Source={x:Reference CreateMeetupPageRoot}}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout>
                                        <Label Text="{Binding MainText}" FontSize="14" FontAttributes="Bold" />
                                        <Label Text="{Binding SecondaryText}" FontSize="12"
                                            TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                    <Button Text="Clear Location" Command="{Binding ClearLocationCommand}" IsVisible="{Binding HasSelectedLocation}"
                        BackgroundColor="Transparent" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" FontSize="12" Padding="0" />
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding ErrorMessage}" TextColor="Red" IsVisible="{Binding HasError}" />

            <Button Text="Create Meetup" Command="{Binding SaveCommand}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="LoopMeet.App.Features.Home.Views.HomePage"
    x:Name="HomePageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Home">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="12">
            <HorizontalStackLayout Spacing="16" VerticalOptions="Center">
                <Border
                    WidthRequest="56"
                    HeightRequest="56"
                    StrokeThickness="0"
                    BackgroundColor="{StaticResource Gray400}">
                    <Border.StrokeShape>
                        <Ellipse />
                    </Border.StrokeShape>
                    <Grid WidthRequest="56" HeightRequest="56">
                        <Label
                            Text="{Binding UserInitial}"
                            FontSize="28" FontAttributes="Bold"
                            TextColor="White"
                            HorizontalOptions="Center" VerticalOptions="Center" />
                        <Image
                            Source="{Binding AvatarUrl}"
                            Aspect="AspectFill"
                            IsVisible="{Binding HasAvatar}" />
                    </Grid>
                </Border>
                <Label Text="{Binding Title}" FontSize="24" FontAttributes="Bold" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <!-- Upcoming Meetups -->
            <VerticalStackLayout
                BindableLayout.ItemsSource="{Binding UpcomingMeetups}"
                Spacing="8"
                IsVisible="{Binding HasUpcomingMeetups}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Padding="16"
                            Style="{StaticResource BubbleCardBorderStyle}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="15" LineBreakMode="TailTruncation" />
                                <Label Text="{Binding DateTimeDisplay}" FontSize="13"
                                    TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                                <Label Text="{Binding LocationDisplay}" FontSize="13"
                                    TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding BindingContext.OpenLocationCommand, Source={x:Reference HomePageRoot}}"
                                            CommandParameter="{Binding .}" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <Label Text="{Binding GroupName}" FontSize="12"
                                    TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <!-- No upcoming meetings card -->
            <Border
                Padding="16"
                Style="{StaticResource BubbleCardBorderStyle}"
                IsVisible="{Binding ShowEmptyState}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="No upcoming meetings" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" />
                    <Label Text="When meetups are scheduled in your groups, they'll appear here."
                        FontSize="13" HorizontalTextAlignment="Center"
                        TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

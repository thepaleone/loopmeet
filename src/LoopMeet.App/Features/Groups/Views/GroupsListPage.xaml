<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="LoopMeet.App.Features.Groups.Views.GroupsListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="GroupsPage"
    Title="LoopMeet">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="24" Spacing="12" Margin="0,0,0,80">
                <Label Text="Groups" FontSize="18" FontAttributes="Bold" />

            <VerticalStackLayout Spacing="8" IsVisible="{Binding IsLoadingOwnedGroups}">
                <!-- Skeleton card 1 -->
                <Border Style="{StaticResource BubbleCardCompactBorderStyle}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                        Padding="12,10" Margin="0,0,0,4">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14,18,16,20" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="54,*" ColumnSpacing="12" VerticalOptions="Center">
                        <Border WidthRequest="48" HeightRequest="48" BackgroundColor="#E2E8F0" StrokeThickness="0">
                            <Border.StrokeShape><Ellipse /></Border.StrokeShape>
                        </Border>
                        <Grid Grid.Column="1" HeightRequest="14" VerticalOptions="Center">
                            <Border BackgroundColor="#E2E8F0" StrokeThickness="0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                            </Border>
                            <Border x:Name="OwnedShimmer1" BackgroundColor="#F8FAFC" Opacity="0.7" WidthRequest="80" HorizontalOptions="Start" />
                        </Grid>
                    </Grid>
                </Border>
                <!-- Skeleton card 2 -->
                <Border Style="{StaticResource BubbleCardCompactBorderStyle}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                        Padding="12,10" Margin="0,0,0,4">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14,18,16,20" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="54,*" ColumnSpacing="12" VerticalOptions="Center">
                        <Border WidthRequest="48" HeightRequest="48" BackgroundColor="#E2E8F0" StrokeThickness="0">
                            <Border.StrokeShape><Ellipse /></Border.StrokeShape>
                        </Border>
                        <Grid Grid.Column="1" HeightRequest="14" VerticalOptions="Center">
                            <Border BackgroundColor="#E2E8F0" StrokeThickness="0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                            </Border>
                            <Border x:Name="OwnedShimmer2" BackgroundColor="#F8FAFC" Opacity="0.7" WidthRequest="80" HorizontalOptions="Start" />
                        </Grid>
                    </Grid>
                </Border>
                <!-- Skeleton card 3 -->
                <Border Style="{StaticResource BubbleCardCompactBorderStyle}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                        Padding="12,10" Margin="0,0,0,4">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14,18,16,20" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="54,*" ColumnSpacing="12" VerticalOptions="Center">
                        <Border WidthRequest="48" HeightRequest="48" BackgroundColor="#E2E8F0" StrokeThickness="0">
                            <Border.StrokeShape><Ellipse /></Border.StrokeShape>
                        </Border>
                        <Grid Grid.Column="1" HeightRequest="14" VerticalOptions="Center">
                            <Border BackgroundColor="#E2E8F0" StrokeThickness="0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                            </Border>
                            <Border x:Name="OwnedShimmer3" BackgroundColor="#F8FAFC" Opacity="0.7" WidthRequest="80" HorizontalOptions="Start" />
                        </Grid>
                    </Grid>
                </Border>
            </VerticalStackLayout>
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding OwnedGroups}" Spacing="8">
                <VerticalStackLayout.Triggers>
                    <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding IsLoadingOwnedGroups}" Value="True">
                        <Setter Property="IsVisible" Value="False" />
                    </DataTrigger>
                </VerticalStackLayout.Triggers>
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Style="{StaticResource BubbleCardCompactBorderStyle}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                            Padding="12,10"
                            Margin="0,0,0,4">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14,18,16,20" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding BindingContext.OpenGroupCommand, Source={x:Reference GroupsPage}}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="54,*" ColumnSpacing="12" VerticalOptions="Center">
                                <!-- Owner avatar + member badge -->
                                <Grid WidthRequest="48" HeightRequest="48">
                                    <!-- Fallback: Gray circle with initial -->
                                    <Border
                                        WidthRequest="48" HeightRequest="48"
                                        BackgroundColor="{StaticResource Gray400}"
                                        StrokeThickness="0">
                                        <Border.StrokeShape><Ellipse /></Border.StrokeShape>
                                        <Label
                                            Text="{Binding OwnerInitial}"
                                            FontSize="18" FontAttributes="Bold"
                                            TextColor="White"
                                            HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <!-- Avatar image (shown when available) -->
                                    <Border
                                        WidthRequest="48" HeightRequest="48"
                                        StrokeThickness="0"
                                        IsVisible="{Binding HasOwnerAvatar}">
                                        <Border.StrokeShape><Ellipse /></Border.StrokeShape>
                                        <Image Source="{Binding OwnerAvatarUrl}" Aspect="AspectFill" />
                                    </Border>
                                    <!-- Member count badge (lower-right) -->
                                    <Border
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray500}}"
                                        StrokeThickness="1.5"
                                        Stroke="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                                        HorizontalOptions="End" VerticalOptions="End"
                                        Padding="4,2"
                                        Margin="0,0,-6,-6">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                        <HorizontalStackLayout Spacing="2" VerticalOptions="Center">
                                            <Grid WidthRequest="13" HeightRequest="9">
                                                <Ellipse Fill="White" Opacity="0.85"
                                                         WidthRequest="7" HeightRequest="7"
                                                         HorizontalOptions="Start" VerticalOptions="Center" />
                                                <Ellipse Fill="White" Opacity="0.85"
                                                         WidthRequest="7" HeightRequest="7"
                                                         HorizontalOptions="Start" VerticalOptions="Center"
                                                         Margin="5,0,0,0" />
                                            </Grid>
                                            <Label
                                                Text="{Binding MemberCount}"
                                                FontSize="9" FontAttributes="Bold"
                                                TextColor="White"
                                                VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </Border>
                                </Grid>
                                <!-- Group name -->
                                <Label
                                    Grid.Column="1"
                                    Text="{Binding Name}"
                                    FontAttributes="Bold" FontSize="15"
                                    LineBreakMode="TailTruncation"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="8" IsVisible="{Binding IsLoadingMemberGroups}">
                <!-- Skeleton card 1 -->
                <Border Style="{StaticResource BubbleCardCompactBorderStyle}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                        Padding="12,10" Margin="0,0,0,4">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14,18,16,20" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="54,*" ColumnSpacing="12" VerticalOptions="Center">
                        <Border WidthRequest="48" HeightRequest="48" BackgroundColor="#E2E8F0" StrokeThickness="0">
                            <Border.StrokeShape><Ellipse /></Border.StrokeShape>
                        </Border>
                        <Grid Grid.Column="1" HeightRequest="14" VerticalOptions="Center">
                            <Border BackgroundColor="#E2E8F0" StrokeThickness="0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                            </Border>
                            <Border x:Name="MemberShimmer1" BackgroundColor="#F8FAFC" Opacity="0.7" WidthRequest="80" HorizontalOptions="Start" />
                        </Grid>
                    </Grid>
                </Border>
                <!-- Skeleton card 2 -->
                <Border Style="{StaticResource BubbleCardCompactBorderStyle}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                        Padding="12,10" Margin="0,0,0,4">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14,18,16,20" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="54,*" ColumnSpacing="12" VerticalOptions="Center">
                        <Border WidthRequest="48" HeightRequest="48" BackgroundColor="#E2E8F0" StrokeThickness="0">
                            <Border.StrokeShape><Ellipse /></Border.StrokeShape>
                        </Border>
                        <Grid Grid.Column="1" HeightRequest="14" VerticalOptions="Center">
                            <Border BackgroundColor="#E2E8F0" StrokeThickness="0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                            </Border>
                            <Border x:Name="MemberShimmer2" BackgroundColor="#F8FAFC" Opacity="0.7" WidthRequest="80" HorizontalOptions="Start" />
                        </Grid>
                    </Grid>
                </Border>
            </VerticalStackLayout>
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding MemberGroups}" Spacing="8">
                <VerticalStackLayout.Triggers>
                    <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding IsLoadingMemberGroups}" Value="True">
                        <Setter Property="IsVisible" Value="False" />
                    </DataTrigger>
                </VerticalStackLayout.Triggers>
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Style="{StaticResource BubbleCardCompactBorderStyle}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                            Padding="12,10"
                            Margin="0,0,0,4">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14,18,16,20" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding BindingContext.OpenGroupCommand, Source={x:Reference GroupsPage}}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="54,*" ColumnSpacing="12" VerticalOptions="Center">
                                <!-- Owner avatar + member badge -->
                                <Grid WidthRequest="48" HeightRequest="48">
                                    <!-- Fallback: Gray circle with initial -->
                                    <Border
                                        WidthRequest="48" HeightRequest="48"
                                        BackgroundColor="{StaticResource Gray400}"
                                        StrokeThickness="0">
                                        <Border.StrokeShape><Ellipse /></Border.StrokeShape>
                                        <Label
                                            Text="{Binding OwnerInitial}"
                                            FontSize="18" FontAttributes="Bold"
                                            TextColor="White"
                                            HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <!-- Avatar image (shown when available) -->
                                    <Border
                                        WidthRequest="48" HeightRequest="48"
                                        StrokeThickness="0"
                                        IsVisible="{Binding HasOwnerAvatar}">
                                        <Border.StrokeShape><Ellipse /></Border.StrokeShape>
                                        <Image Source="{Binding OwnerAvatarUrl}" Aspect="AspectFill" />
                                    </Border>
                                    <!-- Member count badge (lower-right) -->
                                    <Border
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray500}}"
                                        StrokeThickness="1.5"
                                        Stroke="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                                        HorizontalOptions="End" VerticalOptions="End"
                                        Padding="4,2"
                                        Margin="0,0,-6,-6">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                        <HorizontalStackLayout Spacing="2" VerticalOptions="Center">
                                            <Grid WidthRequest="13" HeightRequest="9">
                                                <Ellipse Fill="White" Opacity="0.85"
                                                         WidthRequest="7" HeightRequest="7"
                                                         HorizontalOptions="Start" VerticalOptions="Center" />
                                                <Ellipse Fill="White" Opacity="0.85"
                                                         WidthRequest="7" HeightRequest="7"
                                                         HorizontalOptions="Start" VerticalOptions="Center"
                                                         Margin="5,0,0,0" />
                                            </Grid>
                                            <Label
                                                Text="{Binding MemberCount}"
                                                FontSize="9" FontAttributes="Bold"
                                                TextColor="White"
                                                VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </Border>
                                </Grid>
                                <!-- Group name -->
                                <Label
                                    Grid.Column="1"
                                    Text="{Binding Name}"
                                    FontAttributes="Bold" FontSize="15"
                                    LineBreakMode="TailTruncation"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

                <Label Text="You have no groups yet. Create one to get started." IsVisible="{Binding ShowEmptyState}" />
            </VerticalStackLayout>
        </ScrollView>

        <Button
            VerticalOptions="End"
            HorizontalOptions="End"
            Margin="0,0,16,32"
            WidthRequest="56"
            HeightRequest="56"
            CornerRadius="28"
            Text="+"
            FontSize="28"
            FontAttributes="Bold"
            TextColor="White"
            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
            Command="{Binding CreateGroupCommand}" />
    </Grid>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="LoopMeet.App.Features.Groups.Views.GroupDetailPage"
    x:Name="GroupDetailPageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="{Binding GroupName}">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="24" Spacing="12">
                <Label Text="{Binding GroupName}" FontSize="24" FontAttributes="Bold" />
                <Button Text="Edit Group" Command="{Binding EditGroupCommand}" IsVisible="{Binding IsOwner}" />
                <Label Text="Members" FontAttributes="Bold" FontSize="16" Margin="0,8,0,4" />
                <FlexLayout
                    BindableLayout.ItemsSource="{Binding Members}"
                    Wrap="Wrap"
                    Direction="Row"
                    JustifyContent="Start"
                    AlignItems="Start">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Style="{StaticResource BubbleCardCompactBorderStyle}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                                Padding="10,8"
                                Margin="0,0,8,8">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14,18,16,20" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                    <!-- Avatar circle -->
                                    <Border
                                        WidthRequest="40" HeightRequest="40"
                                        BackgroundColor="{StaticResource Gray400}"
                                        StrokeThickness="0">
                                        <Border.StrokeShape><Ellipse /></Border.StrokeShape>
                                        <Grid WidthRequest="40" HeightRequest="40">
                                            <Label
                                                Text="{Binding Initial}"
                                                FontSize="15" FontAttributes="Bold"
                                                TextColor="White"
                                                HorizontalOptions="Center" VerticalOptions="Center" />
                                            <Image
                                                Source="{Binding AvatarUrl}"
                                                Aspect="AspectFill"
                                                IsVisible="{Binding HasAvatar}" />
                                        </Grid>
                                    </Border>
                                    <!-- Member name -->
                                    <Label
                                        Text="{Binding DisplayName}"
                                        FontSize="12"
                                        MaximumWidthRequest="80"
                                        HorizontalOptions="Center"
                                        HorizontalTextAlignment="Center"
                                        LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>

                <!-- Upcoming Meetups Section -->
                <Label Text="Upcoming Meetups" FontAttributes="Bold" FontSize="16" Margin="0,8,0,4"
                    IsVisible="{Binding HasMeetups}" />
                <VerticalStackLayout
                    BindableLayout.ItemsSource="{Binding Meetups}"
                    Spacing="8"
                    IsVisible="{Binding HasMeetups}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <SwipeView IsEnabled="{Binding BindingContext.IsOwner, Source={x:Reference GroupDetailPageRoot}}">
                                <SwipeView.LeftItems>
                                    <SwipeItems Mode="Execute">
                                        <SwipeItemView
                                            BackgroundColor="#DC2626"
                                            Command="{Binding BindingContext.DeleteMeetupCommand, Source={x:Reference GroupDetailPageRoot}}"
                                            CommandParameter="{Binding .}">
                                            <Grid Padding="14,0">
                                                <HorizontalStackLayout HorizontalOptions="Start" VerticalOptions="Center" Spacing="6">
                                                    <Label Text="🗑" FontSize="16" TextColor="White" />
                                                    <Label Text="Delete" FontAttributes="Bold" TextColor="White" />
                                                </HorizontalStackLayout>
                                            </Grid>
                                        </SwipeItemView>
                                    </SwipeItems>
                                </SwipeView.LeftItems>

                                <Border
                                    Style="{StaticResource BubbleCardCompactBorderStyle}"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                                    Padding="12,10"
                                    Margin="0,0,0,4">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="14,18,16,20" />
                                    </Border.StrokeShape>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding BindingContext.EditMeetupCommand, Source={x:Reference GroupDetailPageRoot}}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="15" LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding DateTimeDisplay}" FontSize="13"
                                            TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                                        <Label Text="{Binding LocationDisplay}" FontSize="13"
                                            TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding BindingContext.OpenLocationCommand, Source={x:Reference GroupDetailPageRoot}}"
                                                    CommandParameter="{Binding .}" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                        <!-- Desktop delete button fallback -->
                                        <HorizontalStackLayout
                                            Spacing="8"
                                            IsVisible="{OnIdiom Phone=False, Tablet=False, Desktop=True, TV=True}">
                                            <Button Text="🗑 Delete"
                                                BackgroundColor="#DC2626" TextColor="White" FontSize="12" Padding="8,4"
                                                Command="{Binding BindingContext.DeleteMeetupCommand, Source={x:Reference GroupDetailPageRoot}}"
                                                CommandParameter="{Binding .}"
                                                IsVisible="{Binding BindingContext.IsOwner, Source={x:Reference GroupDetailPageRoot}}" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </SwipeView>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Add Meetup FAB (above invite) -->
        <Button
            VerticalOptions="End"
            HorizontalOptions="End"
            Margin="0,0,16,100"
            WidthRequest="56"
            HeightRequest="56"
            CornerRadius="28"
            ImageSource="ic_add_meetup.png"
            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
            Command="{Binding AddMeetupCommand}"
            IsVisible="{Binding IsOwner}" />

        <!-- Invite Member FAB -->
        <Button
            VerticalOptions="End"
            HorizontalOptions="End"
            Margin="0,0,16,32"
            WidthRequest="56"
            HeightRequest="56"
            CornerRadius="28"
            ImageSource="ic_invite.png"
            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
            Command="{Binding InviteMemberCommand}"
            IsVisible="{Binding IsOwner}" />
    </Grid>
</ContentPage>
